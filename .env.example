DB_NAME=obedove_menu
DB_USER=obedove_menu_user
DB_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD

# Web landing page
WEB_BIND_IP=0.0.0.0
WEB_PORT=8094
SITE_TITLE=Obedové menu

# Admin CRUD interface on /admin
# Generate for example: openssl rand -hex 24
ADMIN_TOKEN=CHANGE_ME_LONG_RANDOM_ADMIN_TOKEN

# PostgreSQL access for n8n / CloudBeaver on another machine
# Host port 5432 is already used by another DB container, so this project uses 5434.
DB_BIND_IP=0.0.0.0
DB_PUBLIC_PORT=5434
