DB_NAME=obedove_menu
DB_USER=obedove_menu_user
DB_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD

# Web landing page
WEB_BIND_IP=0.0.0.0
WEB_PORT=8094
SITE_TITLE=Obedové menu

# PostgreSQL access for n8n on another machine
# Recommended: use the webserver Tailscale IP here, for example 100.x.y.z.
# Safer default is localhost only; remote n8n will not connect until you change it.
DB_BIND_IP=127.0.0.1
DB_PUBLIC_PORT=5434
